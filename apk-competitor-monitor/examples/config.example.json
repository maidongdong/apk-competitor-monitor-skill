  },
  "weekly": {
    "enabled": true,
    "report_dir": null
  },
  "publish": {
    "enabled": true,
    "dir": "publish",
    "url": "https://example.github.io/competitor-weekly-reports/"
  },
  "notify": {
    "enabled": true,
    "dry_run": false,
    "wecom_webhook_url": ""
  },
  "analysis": {
    "enable_deep_ui_diff": true,
    "enable_static_ui_previews": true,
    "export_pdf": false,
    "export_archive": true
  }
}
