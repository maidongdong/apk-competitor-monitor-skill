{
  "project_id": "example-competitor",
  "app": {
    "name": "Example Android App",
    "package": "com.example.app"
  },
  "source": {
    "type": "wandoujia",
    "app_url": "https://www.wandoujia.com/apps/APP_ID"
  },
  "apk": {
    "state_file": "artifacts/apk-monitor/state.json",
